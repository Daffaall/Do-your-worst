        if p.Character then
            local h = p.Character:FindFirstChildOfClass("Highlight") or Instance.new("Highlight", p.Character)
            h.Enabled, h.DepthMode = state, Enum.HighlightDepthMode.AlwaysOnTop
        end
    end
end)

-- TELEPORT TAB
local function RefreshTP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            Teleport:AddButton("TP to: " .. p.DisplayName, function()
                if p.Character then LocalPlayer.Character:PivotTo(p.Character:GetPivot()) end
            end)
        end
    end
end
Teleport:AddButton("🔄 Refresh Player List", RefreshTP)
RefreshTP()

